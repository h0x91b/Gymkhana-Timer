{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.dev3.0/bin/dev3 task move --status in-progress --if-status-not review-by-ai"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.dev3.0/bin/dev3 task move --status in-progress --if-status-not review-by-ai"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.dev3.0/bin/dev3 task move --status user-questions"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.dev3.0/bin/dev3 task move --status review-by-user --if-status in-progress"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(dev3:*)"
    ]
  }
}
